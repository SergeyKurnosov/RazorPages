@page
@model HW_Academy2.Pages.Groups.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Group</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Group.group_id" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Group.group_name" class="control-label"></label>
                <input asp-for="Group.group_name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Group.group_name" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Group.direction" class="control-label"></label>
                <select asp-for="Group.direction" class="form-control" asp-items="ViewBag.direction" aria-required="true"></select>
                <span asp-validation-for="Group.direction" class="text-danger"></span>
            </div>
            <div class="form-group">
@*                 <label asp-for="Group.learning_days" class="control-label"></label>
                <input asp-for="Group.learning_days" class="form-control" />

                <span asp-validation-for="Group.learning_days" class="text-danger"></span> *@

                <label asp-for="Group.learning_days" class="control-label"></label>
                <ul class="form-control">

                    <h5>Пн</h5>
                    <li><input type="checkbox" asp-for="Group.days1" /></li>
                    <h5>Вт</h5>
                    <li><input type="checkbox" asp-for="Group.days2" /></li>
                    <h5>Ср</h5>
                    <li><input type="checkbox" asp-for="Group.days3" /></li>
                    <h5>Чт</h5>
                    <li><input type="checkbox" asp-for="Group.days4" /></li>
                    <h5>Пт</h5>
                    <li><input type="checkbox" asp-for="Group.days5" /></li>
                    <h5>Сб</h5>
                    <li><input type="checkbox" asp-for="Group.days6" /></li>
                    <h5>Вс</h5>
                    <li><input type="checkbox" asp-for="Group.days7" /></li>

                </ul>


            </div>
            <div class="form-group">
                <label asp-for="Group.start_time" class="control-label"></label>
                <input asp-for="Group.start_time" class="form-control" />
                <span asp-validation-for="Group.start_time" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
