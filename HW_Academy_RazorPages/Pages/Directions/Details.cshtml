@page
@model HW_Academy_RazorPages.Pages.Directions.DetailsModel
@using HW_Academy_RazorPages.Models;

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Direction</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Direction.direction_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Direction.direction_name)
        </dd>
    </dl>

     <h3>Количество групп: @Model.Direction.Groups.Count</h3>
    <ul style="list-style:none">
        @foreach (Group group in Model.Direction.Groups)
        {
            <li>
                @group.group_name
            </li>
        }
    </ul> 

</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Direction.direction_id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
