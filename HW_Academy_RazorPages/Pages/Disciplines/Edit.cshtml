@page
@model HW_Academy_RazorPages.Pages.Disciplines.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Discipline</h4>
<hr />
<dl class="row">
    <dt class="col-sm-2">
        @Html.DisplayNameFor(model => model.Discipline.discipline_id)
    </dt>
    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Discipline.discipline_id)
    </dd>
</dl>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Discipline.discipline_id" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Discipline.discipline_name" class="control-label"></label>
                <input asp-for="Discipline.discipline_name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Discipline.discipline_name" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Discipline.number_of_lessons" class="control-label"></label>
                <input asp-for="Discipline.number_of_lessons" class="form-control" aria-required="true"/>
                <span asp-validation-for="Discipline.number_of_lessons" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
