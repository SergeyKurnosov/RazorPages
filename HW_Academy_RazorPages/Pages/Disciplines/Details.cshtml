@page
@model HW_Academy_RazorPages.Pages.Disciplines.DetailsModel
@using HW_Academy_RazorPages.Models;

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Discipline</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Discipline.discipline_name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Discipline.discipline_name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Discipline.number_of_lessons)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Discipline.number_of_lessons)
        </dd>
    </dl>
</div>
<h5>Количество преподователей: @Model.Discipline.TeachersRelations.Count</h5>
<ul>
    @foreach (TeacherDisciplineRelation tr in @Model.Discipline.TeachersRelations)
    {
        <li>
            @tr.Teacher.last_name @tr.Teacher.first_name @tr.Teacher.middle_name
        </li>

    }
</ul>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Discipline.discipline_id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
